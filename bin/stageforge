#!/usr/bin/env bash
# stageforge - Agent-agnostic multi-stage autonomous development framework
# Usage: stageforge <command> [project-dir] [options]

set -euo pipefail

VERSION="0.4.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$PROJECT_ROOT/core/compat.sh"

# ─── Colors ───
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Defaults ───
RUNNER=""
MODEL=""
TASK=""
DRY_RUN=false
FAST_TRACK=false
ITERATE=false
CONFIG_FILE=""
STAGE_MAX_RETRIES="${STAGEFORGE_MAX_RETRIES:-3}"

# ─── Shared modules ───
# shellcheck source=../core/signal.sh
source "$PROJECT_ROOT/core/signal.sh"
# shellcheck source=../core/validate.sh
source "$PROJECT_ROOT/core/validate.sh"

# ─── Help ───
usage() {
    cat <<EOF
${BOLD}stageforge${NC} v${VERSION} - Multi-stage autonomous development framework

${BOLD}Usage:${NC}
  stageforge init <project-dir>            Initialize a new project
  stageforge run <project-dir> -t <task>   Run full pipeline (Plan->Build->Review->Deliver)
  stageforge iterate <project-dir> -t <task>  Iterate on existing project (Brownfield)
  stageforge quick -t <task>               Quick track for simple tasks
  stageforge status <project-dir>          Check pipeline status
  stageforge resume <project-dir>          Resume from last completed stage

${BOLD}Options:${NC}
  -r, --runner <runner>        Agent runner: claude-code, codex-cli, or path to custom runner
  -m, --model <model>          Override model for all stages
  -t, --task <description>     Task description (required for run/iterate/quick)
  -c, --config <path>          Path to config file (default: ./stageforge.yaml)
      --dry-run                Only run Planner stage, then stop
      --planner-model <model>  Model for Planner stage
      --builder-model <model>  Model for Builder stage
      --reviewer-model <model> Model for Reviewer stage
      --consultant-model <model> Model for Consultant stage
  -v, --version                Show version
  -h, --help                   Show this help

${BOLD}Examples:${NC}
  # Initialize and run a new project
  stageforge init my-app
  stageforge run my-app -t "Build a REST API with Express and TypeScript"

  # Quick track for simple scripts
  stageforge quick -t "Write a Python script to batch rename files"

  # Iterate on existing project with a specific runner
  stageforge iterate my-app -t "Add authentication middleware" -r claude-code

  # Dry run to review the plan first
  stageforge run my-app -t "Add WebSocket support" --dry-run

${BOLD}Runners:${NC}
  claude-code    Claude Code CLI (claude --print)
  codex-cli      OpenAI Codex CLI (codex)
  custom         Any executable accepting run/check/name commands
EOF
    exit 0
}

# ─── Utility Functions ───
info()  { echo -e "${BLUE}[INFO]${NC} $*"; }
ok()    { echo -e "${GREEN}[OK]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*" >&2; exit 1; }
stage() { echo -e "\n${CYAN}${BOLD}━━━ Stage $1: $2 ━━━${NC}"; }

# ─── Load Config ───
load_config() {
    local project_dir="$1"
    local config_path="${CONFIG_FILE:-${project_dir}/stageforge.yaml}"

    if [[ -f "$config_path" ]]; then
        info "Loading config: $config_path"
        # Simple YAML parsing via grep (no yq dependency required)
        PLANNER_MODEL="${PLANNER_MODEL:-$(grep_oP 'planner:\s*\\K.*' "$config_path" || true)}"
        BUILDER_MODEL="${BUILDER_MODEL:-$(grep_oP 'builder:\s*\\K.*' "$config_path" || true)}"
        REVIEWER_MODEL="${REVIEWER_MODEL:-$(grep_oP 'reviewer:\s*\\K.*' "$config_path" || true)}"
        CONSULTANT_MODEL="${CONSULTANT_MODEL:-$(grep_oP 'consultant:\s*\\K.*' "$config_path" || true)}"
        RUNNER="${RUNNER:-$(grep_oP 'runner:\s*\\K.*' "$config_path" || true)}"
    fi

    # Apply global model override
    if [[ -n "$MODEL" ]]; then
        PLANNER_MODEL="$MODEL"
        BUILDER_MODEL="$MODEL"
        REVIEWER_MODEL="$MODEL"
        CONSULTANT_MODEL="$MODEL"
    fi
}

# ─── Detect Runner ───
detect_runner() {
    if [[ -n "$RUNNER" ]]; then
        # Check if it's a built-in runner name
        local runner_path="$PROJECT_ROOT/runners/${RUNNER}.sh"
        if [[ -f "$runner_path" ]]; then
            echo "$runner_path"
            return
        fi
        # Check if it's a path to a custom runner
        if [[ -f "$RUNNER" ]]; then
            echo "$RUNNER"
            return
        fi
        error "Runner not found: $RUNNER"
    fi

    # Auto-detect: try each built-in runner
    for runner_name in claude-code codex-cli; do
        local runner_path="$PROJECT_ROOT/runners/${runner_name}.sh"
        if [[ -f "$runner_path" ]]; then
            source "$runner_path"
            if runner_check 2>/dev/null; then
                echo "$runner_path"
                return
            fi
        fi
    done

    error "No agent runner detected. Install Claude Code CLI or Codex CLI, or specify a runner with -r."
}

# ─── Init Command ───
cmd_init() {
    local project_dir="$1"

    if [[ -z "$project_dir" ]]; then
        error "Project directory required. Usage: stageforge init <project-dir>"
    fi

    mkdir -p "$project_dir"/{docs,stages,src}

    # Copy default config if not exists
    if [[ ! -f "$project_dir/stageforge.yaml" ]]; then
        cp "$PROJECT_ROOT/config/stageforge.yaml" "$project_dir/stageforge.yaml"
    fi

    # Write .gitignore
    cat > "$project_dir/.gitignore" <<'EOF'
stages/.stage_*
stages/.pipeline_*
EOF

    ok "Project initialized: $project_dir"
    info "Next: stageforge run $project_dir -t \"your task description\""
}

# ─── Status Command ───
cmd_status() {
    local project_dir="$1"

    if [[ ! -d "$project_dir" ]]; then
        error "Project directory not found: $project_dir"
    fi

    echo -e "${BOLD}Project:${NC} $project_dir"
    echo ""

    local stages=("0:Planner" "1:Builder" "2:Reviewer" "3:Consultant")
    local all_done=true

    for stage_def in "${stages[@]}"; do
        local num="${stage_def%%:*}"
        local name="${stage_def##*:}"
        local signal="$project_dir/stages/.stage_${num}_done"

        if [[ -f "$signal" ]]; then
            local ts
            ts=$(cat "$signal" | head -1)
            ok "Stage $num ($name): completed at $ts"
        else
            echo -e "${YELLOW}[ ]${NC} Stage $num ($name): pending"
            all_done=false
        fi
    done

    echo ""
    if [[ -f "$project_dir/stages/.pipeline_done" ]]; then
        ok "Pipeline: COMPLETE"
    elif [[ "$all_done" == "true" ]]; then
        warn "Pipeline: all stages done but no .pipeline_done signal"
    else
        info "Pipeline: in progress"
    fi

    local cur_run_id
    cur_run_id=$(signal_current_run_id "$project_dir")
    if [[ -n "$cur_run_id" ]]; then
        info "Current run_id: $cur_run_id"
    fi
}

# ─── Resume Command ───
cmd_resume() {
    local project_dir="$1"
    local task="${TASK:-resume from last completed stage}"

    # Find last *recorded* completed stage (signal existence only).
    local signalled_last=-1
    for i in 0 1 2 3; do
        if [[ -f "$project_dir/stages/.stage_${i}_done" ]]; then
            signalled_last=$i
        fi
    done

    # Reconcile against artifacts on disk: a stage may be marked done while its
    # outputs are gone. Resume from the last artifact-backed stage instead.
    local last_complete
    last_complete=$(reconcile_resume_point "$project_dir")

    if [[ $last_complete -lt $signalled_last ]]; then
        warn "Recorded progress (Stage $signalled_last) is ahead of intact artifacts (Stage $last_complete). Re-running from Stage $((last_complete + 1))."
    fi

    if [[ $last_complete -eq -1 ]]; then
        info "No artifact-backed completed stages found. Starting from Stage 0."
        cmd_run "$project_dir"
    elif [[ $last_complete -eq 3 ]]; then
        ok "Pipeline already complete."
        cmd_status "$project_dir"
    else
        local next_stage=$((last_complete + 1))
        info "Resuming from Stage $next_stage (last complete: Stage $last_complete)"
        run_pipeline "$project_dir" "$task" "$next_stage"
    fi
}

# ─── Stage Execution Helper ───
# Runs a single stage with prerequisite validation, signal verification, and retries.
# Usage: run_stage_with_verify <stage_num> <stage_name> <prompt_text> <model>
run_stage_with_verify() {
    local stage_num="$1"
    local stage_name="$2"
    local prompt_text="$3"
    local model="${4:-}"

    if ! validate_prerequisites "$stage_num" "$project_dir"; then
        if [[ "$stage_num" == "0" ]]; then
            : # Planner only needs the project dir; warning already printed.
        else
            error "Stage $stage_num ($stage_name) prerequisites not met."
        fi
    fi

    local attempt=1
    while [[ $attempt -le $STAGE_MAX_RETRIES ]]; do
        info "Stage $stage_num ($stage_name) — attempt $attempt/$STAGE_MAX_RETRIES (run_id=$STAGEFORGE_RUN_ID)"

        if runner_run "$stage_name" "$prompt_text" "$project_dir" "$model"; then
            if signal_verify "$stage_num" "$project_dir" "$STAGEFORGE_RUN_ID"; then
                ok "Stage $stage_num ($stage_name) verified."
                return 0
            fi

            # Distinguish between "no file" and "stale file from previous run".
            if signal_check "$stage_num" "$project_dir"; then
                local stale
                stale=$(signal_read_run_id "$stage_num" "$project_dir" || true)
                warn "Stage $stage_num signal found but run_id mismatch (expected=$STAGEFORGE_RUN_ID, got=${stale:-<missing>}). Treating as stale."
                rm -f "$project_dir/stages/.stage_${stage_num}_done"
            else
                warn "Stage $stage_num ran but did not write signal file."
            fi
        else
            warn "Stage $stage_num ($stage_name) runner returned non-zero (attempt $attempt)."
        fi

        attempt=$((attempt + 1))
    done

    signal_fail "$stage_num" "$project_dir" "Failed after $STAGE_MAX_RETRIES attempts"
    error "Stage $stage_num ($stage_name) failed after $STAGE_MAX_RETRIES attempts."
}

# ─── Run Pipeline ───
run_pipeline() {
    local project_dir="$1"
    local task="$2"
    local start_stage="${3:-0}"

    # Normalize to an absolute path so runners that `cd` internally cannot
    # corrupt subsequent retries (or downstream relative path resolution).
    if [[ ! -d "$project_dir" ]]; then
        error "Project directory not found: $project_dir"
    fi
    project_dir="$(cd "$project_dir" && pwd)"

    load_config "$project_dir"
    local runner_path
    runner_path=$(detect_runner)
    source "$runner_path"

    # Wipe any stale signal files from start_stage onwards so old runs cannot
    # falsely satisfy validate_prerequisites for the new run.
    signal_clean_from "$project_dir" "$start_stage"

    # Allocate a fresh run-ID for this invocation and export it so that runners
    # / AI subprocesses can embed it into the signal files they write.
    local run_id
    run_id=$(signal_init_run "$project_dir")
    export STAGEFORGE_RUN_ID="$run_id"
    export STAGEFORGE_RUN_ID="$(signal_current_run_id "$project_dir")"
    # Match policy.py resolution: yaml/yml first, then json.
    if [ -f "$HOME/.stageforge/policy.yaml" ]; then
        export POLICY_FILE="$HOME/.stageforge/policy.yaml"
    elif [ -f "$HOME/.stageforge/policy.yml" ]; then
        export POLICY_FILE="$HOME/.stageforge/policy.yml"
    elif [ -f "$HOME/.stageforge/policy.json" ]; then
        export POLICY_FILE="$HOME/.stageforge/policy.json"
    fi

    info "Runner: $(runner_name)"
    info "Project: $project_dir"
    info "Task: $task"
    info "Start stage: $start_stage"
    info "Run ID: $run_id"

    local run_id_block="## Run ID\nWrite this exact id into stages/.stage_<N>_done as the second line in the form 'run_id: <id>'. The same value is exported as the STAGEFORGE_RUN_ID environment variable.\n$run_id"

    # Stage 0: Planner
    if [[ $start_stage -le 0 ]]; then
        stage "0" "Planner"
        local planner_prompt
        planner_prompt=$(cat "$PROJECT_ROOT/prompts/planner.md")
        run_stage_with_verify "0" "planner" \
            "$planner_prompt\n\n$run_id_block\n\n## Task\n$task\n\n## Project Directory\n$project_dir" \
            "${PLANNER_MODEL:-}"

        if [[ "$DRY_RUN" == true ]]; then
            ok "Dry run complete. Review: $project_dir/docs/PLAN.md"
            ok "Remove --dry-run to continue the pipeline."
            exit 0
        fi
    fi

    # Stage 1: Builder
    if [[ $start_stage -le 1 ]]; then
        stage "1" "Builder"
        local builder_prompt
        builder_prompt=$(cat "$PROJECT_ROOT/prompts/builder.md")
        run_stage_with_verify "1" "builder" \
            "$builder_prompt\n\n$run_id_block\n\n## Plan Location\n$project_dir/docs/PLAN.md\n\n## Project Directory\n$project_dir" \
            "${BUILDER_MODEL:-}"
    fi

    # Stage 2: Reviewer
    if [[ $start_stage -le 2 ]]; then
        stage "2" "Reviewer"
        local reviewer_prompt
        reviewer_prompt=$(cat "$PROJECT_ROOT/prompts/reviewer.md")
        run_stage_with_verify "2" "reviewer" \
            "$reviewer_prompt\n\n$run_id_block\n\n## Project Directory\n$project_dir" \
            "${REVIEWER_MODEL:-}"
    fi

    # Stage 3: Consultant
    if [[ $start_stage -le 3 ]]; then
        stage "3" "Consultant"
        local consultant_prompt
        consultant_prompt=$(cat "$PROJECT_ROOT/prompts/consultant.md")
        run_stage_with_verify "3" "consultant" \
            "$consultant_prompt\n\n$run_id_block\n\n## Project Directory\n$project_dir" \
            "${CONSULTANT_MODEL:-}"
    fi

    # Pipeline complete — record the run that produced it.
    {
        echo "$(date_iso)"
        echo "run_id: $run_id"
    } > "$project_dir/stages/.pipeline_done"
    echo ""
    ok "Pipeline complete! 🎉"
    cmd_status "$project_dir"
}

# ─── Run Command ───
cmd_run() {
    local project_dir="$1"

    if [[ -z "$project_dir" ]]; then
        error "Project directory required. Usage: stageforge run <project-dir> -t <task>"
    fi
    if [[ -z "$TASK" ]]; then
        error "Task description required. Use -t or --task."
    fi

    run_pipeline "$project_dir" "$TASK" 0
}

# ─── Iterate Command ───
cmd_iterate() {
    local project_dir="$1"

    if [[ -z "$project_dir" ]]; then
        error "Project directory required. Usage: stageforge iterate <project-dir> -t <task>"
    fi
    if [[ -z "$TASK" ]]; then
        error "Task description required. Use -t or --task."
    fi
    if [[ ! -d "$project_dir/src" ]] && [[ ! -d "$project_dir/contracts" ]] && [[ ! -d "$project_dir/lib" ]]; then
        error "No source code found. Use 'run' for new projects."
    fi

    # Brownfield: set environment variable for prompts
    export STAGEFORGE_MODE="brownfield"

    run_pipeline "$project_dir" "$TASK" 0
}

# ─── Quick Command ───
cmd_quick() {
    if [[ -z "$TASK" ]]; then
        error "Task description required. Use -t or --task."
    fi

    # Create temp project dir
    local project_dir
    project_dir=$(mktemp -d -t stageforge-quick-XXXXXX)
    mkdir -p "$project_dir"/{docs,stages,src}

    load_config "$project_dir"
    local runner_path
    runner_path=$(detect_runner)
    source "$runner_path"

    info "Runner: $(runner_name)"
    info "Quick track: $TASK"

    stage "⚡" "Quick Build"
    local builder_prompt
    builder_prompt=$(cat "$PROJECT_ROOT/prompts/builder.md")

    if runner_run "builder" "$builder_prompt\n\n## Task (Quick Track)\n$TASK\n\n## Project Directory\n$project_dir\n\n## Instructions\nBuild and verify the solution. This is a quick-track task - keep it simple and focused." "$project_dir" "${BUILDER_MODEL:-}"; then
        ok "Quick track complete! 🎉"
        info "Output: $project_dir"
    else
        error "Quick track failed."
    fi
}

# ─── Parse Arguments ───
COMMAND=""
PROJECT_DIR=""
PLANNER_MODEL=""
BUILDER_MODEL=""
REVIEWER_MODEL=""
CONSULTANT_MODEL=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        init|run|iterate|quick|status|resume)
            COMMAND="$1"
            shift
            if [[ "$COMMAND" != "quick" ]] && [[ $# -gt 0 ]] && [[ ! "$1" =~ ^- ]]; then
                PROJECT_DIR="$1"
                shift
            fi
            ;;
        -r|--runner)     RUNNER="$2"; shift 2 ;;
        -m|--model)      MODEL="$2"; shift 2 ;;
        -t|--task)       TASK="$2"; shift 2 ;;
        -c|--config)     CONFIG_FILE="$2"; shift 2 ;;
        --dry-run)       DRY_RUN=true; shift ;;
        --planner-model)     PLANNER_MODEL="$2"; shift 2 ;;
        --builder-model)     BUILDER_MODEL="$2"; shift 2 ;;
        --reviewer-model)    REVIEWER_MODEL="$2"; shift 2 ;;
        --consultant-model)  CONSULTANT_MODEL="$2"; shift 2 ;;
        -v|--version)    echo "stageforge v${VERSION}"; exit 0 ;;
        -h|--help)       usage ;;
        *)               error "Unknown option: $1" ;;
    esac
done

# ─── Execute ───
case "$COMMAND" in
    init)     cmd_init "$PROJECT_DIR" ;;
    run)      cmd_run "$PROJECT_DIR" ;;
    iterate)  cmd_iterate "$PROJECT_DIR" ;;
    quick)    cmd_quick ;;
    status)   cmd_status "$PROJECT_DIR" ;;
    resume)   cmd_resume "$PROJECT_DIR" ;;
    *)        usage ;;
esac
